@model ErrorViewModel
@{
    ViewData["Title"] = "Błąd";
}

<h1 class="text-danger">Błąd</h1>
<h2 class="text-danger">Wystąpił błąd podczas przetwarzania żądania.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Identyfikator żądania:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Tryb deweloperski</h3>
<p>
    Przełączenie aplikacji w tryb <strong>Development</strong> spowoduje wyświetlenie szczegółowych informacji o błędzie.
</p>
<p>
    <strong>Tryb deweloperski nie powinien być włączony w środowisku produkcyjnym.</strong>
    Może to prowadzić do ujawnienia wrażliwych danych użytkownikom.
    Do lokalnego debugowania ustaw zmienną środowiskową
    <strong>ASPNETCORE_ENVIRONMENT</strong> na <strong>Development</strong>
    i uruchom ponownie aplikację.
</p>